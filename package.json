{
  "name": "@affordance/signal",
  "version": "0.2.0",
  "description": "Multi-provider usage monitor for AI coding agents. Signal, not noise.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "signal": "./src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "compile": "bun build src/index.ts --compile --outfile=dist/signal",
    "test": "bun test",
    "lint": "biome check src tests",
    "format": "biome format --write src tests"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1",
    "smol-toml": "^1.3.1"
  },
  "optionalDependencies": {
    "systeminformation": "^5.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/react": "^18.3.12",
    "bun-types": "latest",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
