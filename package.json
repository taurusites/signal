{
  "name": "@affordance/signal",
  "version": "0.1.0",
  "description": "Multi-provider usage monitor for AI coding agents. Signal, not noise.",
  "license": "MIT",
  "type": "module",
  "bin": {
  "signal": "./dist/index.js"
},
"scripts": {
  "dev": "bun run src/index.ts",
  "build": "bun build src/index.ts --target=bun --outdir=dist",
  "compile": "bun build src/index.ts --compile --outfile=dist/signal",
  "test": "bun test",
  "lint": "biome check src tests",
  "format": "biome format --write src tests"
},
"dependencies": {
  "better-sqlite3": "^11.5.0",
  "commander": "^12.1.0",
  "ink": "^5.0.1",
  "react": "^18.3.1",
  "smol-toml": "^1.3.1"
},
"optionalDependencies": {
  "systeminformation": "^5.23.0"
},
"trustedDependencies": ["@biomejs/biome", "better-sqlite3"],
"devDependencies": {
  "@biomejs/biome": "^1.9.4",
  "@types/better-sqlite3": "^7.6.11",
  "@types/react": "^18.3.12",
  "bun-types": "latest",
  "ink-testing-library": "^4.0.0",
  "typescript": "^5.6.0"
}
}
